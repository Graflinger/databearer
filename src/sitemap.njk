---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- for page in collections.all %}
    {%- if not page.data.excludeFromSitemap %}
    <url>
      <loc>{{ site.url }}{{ page.url | url }}</loc>
      {%- if page.data.lastUpdated %}
      <lastmod>{{ page.data.lastUpdated | htmlDateString }}</lastmod>
      {%- elif page.date %}
      <lastmod>{{ page.date | htmlDateString }}</lastmod>
      {%- endif %}
      {%- if page.data.changefreq %}
      <changefreq>{{ page.data.changefreq }}</changefreq>
      {%- elif page.data.tags and 'post' in page.data.tags %}
      <changefreq>monthly</changefreq>
      {%- else %}
      <changefreq>weekly</changefreq>
      {%- endif %}
      {%- if page.data.priority %}
      <priority>{{ page.data.priority }}</priority>
      {%- elif page.url == '/' %}
      <priority>1.0</priority>
      {%- elif page.data.tags and 'post' in page.data.tags %}
      <priority>0.8</priority>
      {%- else %}
      <priority>0.6</priority>
      {%- endif %}
    </url>
    {%- endif %}
  {%- endfor %}
</urlset>
