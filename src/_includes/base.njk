<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        {# Primary Meta Tags #}
        <title>{{ title or "Databearer Blog" }}</title>
        <meta name="title" content="{{ title or 'Databearer Blog' }}">
        <meta name="description" content="{{ excerpt or description or 'Databearer Blog - Insights and analysis on data, energy, and technology trends' }}">
        <meta name="author" content="Databearer">

        {# Canonical URL #}
        <link rel="canonical" href="{{ site.url }}{{ page.url }}">

        {# Open Graph / Facebook #}
        <meta property="og:type" content="{{ 'article' if date else 'website' }}">
        <meta property="og:url" content="{{ site.url }}{{ page.url }}">
        <meta property="og:title" content="{{ title or 'Databearer Blog' }}">
        <meta property="og:description" content="{{ excerpt or description or 'Databearer Blog - Insights and analysis on data, energy, and technology trends' }}">
        <meta property="og:image" content="{{ image or site.url ~ '/images/logo_transparent.png' }}">
        <meta property="og:image:width" content="1070">
        <meta property="og:image:height" content="388">
        <meta property="og:image:alt" content="{{ title or 'Databearer Blog' }}">
        <meta property="og:locale" content="de_DE">
        <meta property="og:site_name" content="Databearer">
        {% if date %}
            <meta property="article:published_time" content="{{ date | htmlDateString }}">
            {% if lastUpdated %}
                <meta property="article:modified_time" content="{{ lastUpdated | htmlDateString }}">
            {% endif %}
        {% endif %}

        {# Twitter #}
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:url" content="{{ site.url }}{{ page.url }}">
        <meta name="twitter:title" content="{{ title or 'Databearer Blog' }}">
        <meta name="twitter:description" content="{{ excerpt or description or 'Databearer Blog - Insights and analysis on data, energy, and technology trends' }}">
        <meta name="twitter:image" content="{{ image or site.url ~ '/images/logo_transparent.png' }}">
        <meta name="twitter:image:alt" content="{{ title or 'Databearer Blog' }}">

        {# Favicon #}
        <link rel="icon" type="image/png" sizes="32x32" href="/images/logo_circle.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/images/logo_circle.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/images/logo_circle.png">

        {# Robots #}
        <meta name="robots" content="index, follow">

        {# RSS Feed #}
        <link rel="alternate" type="application/atom+xml" title="Databearer Blog Feed" href="{{ site.url }}/feed.xml">

        {# Structured Data (JSON-LD) #}
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "{{ 'Article' if date else 'WebSite' }}",
                {% if date %}
                    "headline": "{{ title }}",
                    "description": "{{ excerpt or description }}",
                    "image": "{{ image or site.url ~ '/images/logo_transparent.png' }}",
                    "datePublished": "{{ date | htmlDateString }}",
                    {% if lastUpdated %}
                        "dateModified": "{{ lastUpdated | htmlDateString }}",
                    {% endif %}
                    "author": {
                        "@type": "Organization",
                        "name": "Databearer"
                    },
                    "publisher": {
                        "@type": "Organization",
                        "name": "Databearer",
                        "logo": {
                            "@type": "ImageObject",
                            "url": "{{ site.url }}/images/logo_transparent.png"
                        }
                    }
                {% else %}
                    "name": "Databearer Blog",
                    "url": "{{ site.url }}",
                    "description": "Insights and analysis on data, energy, and technology trends"
                {% endif %}
            }
        </script>

        {# Breadcrumb Structured Data #}
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "Home",
                        "item": "{{ site.url }}"
                    }
                    {%- if topic and topic.length > 0 -%}, {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "{% if topic[0] == 'energie' %}Energie{% elif topic[0] == 'wirtschaft' %}Wirtschaft{% elif topic[0] == 'politik-und-gesellschaft' %}Politik & Gesellschaft{% else %}{{ topic[0] }}{% endif %}",
                            "item": "{{ site.url }}/themen/{{ topic[0] }}"
                        }
                    {%- endif -%}
                    {%- if date -%}, {
                            "@type": "ListItem",
                            "position": {{ 3 if (topic and topic.length > 0) else 2 }},
                            "name": "{{ title }}",
                            "item": "{{ site.url }}{{ page.url }}"
                        }
                    {%- elif page.url != '/' and not topic -%}, {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "{{ title }}",
                            "item": "{{ site.url }}{{ page.url }}"
                        }
                    {%- endif -%}
                ]
            }
        </script>

        {%- if page.url == '/' -%}
            {# Organization Structured Data for Homepage #}
            <script type="application/ld+json">
                {
                    "@context": "https://schema.org",
                    "@type": "Organization",
                    "name": "Databearer",
                    "url": "{{ site.url }}",
                    "logo": {
                        "@type": "ImageObject",
                        "url": "{{ site.url }}/images/logo_transparent.png",
                        "width": 1070,
                        "height": 388
                    },
                    "description": "{{ site.description }}",
                    "founder": {
                        "@type": "Person",
                        "name": "{{ site.author }}"
                    },
                    "sameAs": ["https://bsky.app/profile/databearer.bsky.social", "https://x.com/databearerde"]
                }
            </script>
        {%- endif -%}

        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body>
        <header class="site-header">
            <div class="container">
                <button class="topics-menu-toggle" aria-label="Menü öffnen" aria-expanded="false">
                    <span class="hamburger-icon"></span>
                </button>
                <div class="logo">
                    <a href="/">
                        <img src="/images/logo_transparent.png" alt="Databearer Logo" class="logo-image">
                    </a>
                </div>
            </div>
        </header>

        <div class="menu-backdrop"></div>

        <nav class="topics-nav">
            <div class="container">
                <ul class="topics-menu">
                    <li>
                        <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Alle Posts</a>
                    </li>
                    <li>
                        <a href="/themen/energie" {% if page.url.startsWith("/themen/energie") %}aria-current="page"{% endif %}>Energie</a>
                    </li>
                    <li>
                        <a href="/themen/politik-und-gesellschaft" {% if page.url.startsWith("/themen/politik-und-gesellschaft") %}aria-current="page"{% endif %}>Politik & Gesellschaft</a>
                    </li>
                    <li>
                        <a href="/themen/wirtschaft" {% if page.url.startsWith("/themen/wirtschaft") %}aria-current="page"{% endif %}>Wirtschaft</a>
                    </li>
                    <li>
                        <a href="/suche" {% if page.url.startsWith("/suche") %}aria-current="page"{% endif %}>Suche</a>
                    </li>
                    <li>
                        <a href="/supportme" {% if page.url.startsWith("/supportme") %}aria-current="page"{% endif %}>Supporte mich</a>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="site-main" id="main-content">
            <div class="container">
                {{ content | safe }}
            </div>
        </main>

        <footer class="site-footer">
            <div class="container">
                <nav class="footer-nav">
                    <ul>

                        <li>
                            <a href="/impressum/">Impressum</a>
                        </li>
                        <li>
                            <a href="/quellen/">Quellen</a>
                        </li>
                        <li>
                            <a href="/datenschutzerklärung/">Datenschutzerklärung</a>
                        </li>
                        <li>
                            <a href="/about/">Über mich</a>
                        </li>

                    </ul>
                </nav>
                <p class="copyright">&copy; {{ helpers.year }} Databearer. All rights reserved.</p>
            </div>
        </footer>
        <script src="/js/menu.js"></script>
    </body>
</html>