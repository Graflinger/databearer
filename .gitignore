# ===== Monorepo root .gitignore =====
# Subprojects have their own .gitignore: pipeline/, frontend/, image-generation/

# OS
.DS_Store

# Python (cross-cutting)
**/__pycache__/
*.pyc
.venv/

# Secrets — never commit any .env or credentials
**/.env
!**/.env.example
**/credentials.*

# Generated image output (scratch dir, lives outside image-generation/)
generated-images/
