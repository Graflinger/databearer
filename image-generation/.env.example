# Azure FLUX image generation — copy to .env and fill in
# Get the key from the Azure portal (rotate if it was ever exposed).
AZURE_FLUX_API_KEY=

# Optional overrides (defaults are used if unset):
AZURE_FLUX_GENERATION_URL=https://azure.services.ai.azure.com/providers/blackforestlabs/v1/flux-2-pro?api-version=preview
IMAGE_OUTPUT_DIR=../generated-images
