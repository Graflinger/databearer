{
  "name": "eleventy_test",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:charts": "node \"src/data_ingestion/generate-charts.js\"",
    "css:build": "sass src/scss/style.scss src/css/style.css --no-source-map",
    "css:watch": "sass --watch src/scss/style.scss src/css/style.css",
    "start": "concurrently \"npm run css:watch\" \"eleventy --serve\"",
    "build": "npm run css:build && eleventy",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\" \".eleventy.js\" --ignore-pattern \"src/js/charts/**\" --ignore-pattern \"!/.eleventy.js\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "sass": "^1.78.0"
  },
  "dependencies": {
    "csv-parse": "^6.1.0",
    "echarts": "^6.0.0"
  }
}
